{
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm --filter @sayak-chatbot/shared build && pnpm --filter dashboard build",
  "outputDirectory": ".next",
  "installCommand": "echo 'Install handled in buildCommand'",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api-url.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
