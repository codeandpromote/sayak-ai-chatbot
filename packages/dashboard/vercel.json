{
  "framework": "nextjs",
  "buildCommand": "cd ../.. && npx pnpm@9 install && npx pnpm@9 --filter @sayak-chatbot/shared build && cd packages/dashboard && npx next build",
  "outputDirectory": ".next",
  "installCommand": "echo 'Install handled in buildCommand'",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sayak-ai-chatbot.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
