{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx pnpm@9 install --reporter=default)",
      "Bash(npx pnpm@9 --filter @sayak-chatbot/shared build)",
      "Bash(npx pnpm@9 --filter api prisma:generate)",
      "Bash(npx pnpm@9 build:api)",
      "Bash(npx pnpm@9 --filter api add socket.io @types/pdf-parse)",
      "Bash(npx pnpm@9 build:widget)",
      "Bash(npx pnpm@9 --filter api add -D eslint @typescript-eslint/parser @typescript-eslint/eslint-plugin)",
      "Bash(npx pnpm@9 --filter api remove eslint @typescript-eslint/parser @typescript-eslint/eslint-plugin)",
      "Bash(npx pnpm@9 --filter api add -D eslint@8 @typescript-eslint/parser@7 @typescript-eslint/eslint-plugin@7)",
      "Bash(npx pnpm@9 --filter api lint)"
    ]
  }
}
