{
  "name": "sayak-ai-chatbot",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "build:api": "pnpm --filter api build",
    "build:dashboard": "pnpm --filter dashboard build",
    "build:widget": "pnpm --filter widget build",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:generate": "pnpm --filter api prisma:generate",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "pnpm": "^9.15.9",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
